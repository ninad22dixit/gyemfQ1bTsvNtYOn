FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir "mlflow>=2.10,<3.0"

RUN mkdir -p /mlflow/mlruns

EXPOSE 5000

CMD ["mlflow", "server", \
     "--host", "0.0.0.0", \
     "--port", "5000", \
     "--backend-store-uri", "sqlite:////mlflow/mlflow.db", \
     "--default-artifact-root", "file:///mlflow/mlruns", \
     "--serve-artifacts"]