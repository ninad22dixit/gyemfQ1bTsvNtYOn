# Copy this file to .env and fill in your private values.
# .env is ignored by git; do not commit real credentials.

# Google Sheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART_IS_THE_ID>/edit
GOOGLE_SHEET_ID=

# Sheet tab and range containing the key,value config table.
GOOGLE_SHEET_RANGE=Config!A:B

# Preferred: path to a local service-account JSON credential file.
# Share the Google Sheet with the service account's client_email.
GOOGLE_APPLICATION_CREDENTIALS=C:\Users\ninad\.config\bitcoin-trading-agent\google-service-account.json

# Alternative: paste the full service-account JSON on one line instead of using a file path.
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional fallback for a public/published CSV export URL.
# GOOGLE_SHEET_CONFIG_URL=

# Telegram trade alerts. Create a bot with BotFather and put the target chat ID here.
TELEGRAM_NOTIFICATIONS_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional override for dedupe state shared across pipeline entrypoints.
# TELEGRAM_NOTIFICATIONS_STATE_PATH=reports/telegram_notified.json

# Gmail weekly summary. Use a Gmail app password, not your normal account password.
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENTS=
